# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-api-key>
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# Deployment names (must match what you created in Azure AI Studio)
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=ada-002

# ── Chatbot topic ─────────────────────────────────────────────────────────────
# Change this to switch the restricted domain without touching any code.
# Available built-in topics: gardening, motor_vehicles, cinematography
CHATBOT_TOPIC=gardening

# Minimum cosine similarity (0–1) between a user query and the topic anchors.
# Lower = more permissive; higher = stricter. Default 0.30 works well for Ada-002.
TOPIC_RELEVANCE_THRESHOLD=0.30

# ── Conversation history ──────────────────────────────────────────────────────
# Maximum number of back-and-forth turns kept in the rolling context window.
# Each turn = 1 user message + 1 assistant message (2 entries).
# Increase for richer multi-turn memory; decrease to save tokens.
MAX_HISTORY_TURNS=10

# ── Moderation thresholds ─────────────────────────────────────────────────────
# JSON-encoded dict; values are risk-score thresholds (0.0–1.0).
# "review" — input moderation threshold (requests above this are flagged)
# "block"  — output moderation threshold (responses above this are blocked)
MODERATION_THRESHOLDS={"block": 0.8, "review": 0.5}

# ── Rate limiting ─────────────────────────────────────────────────────────────
# JSON-encoded dict; values are max requests per minute.
RATE_LIMITS={"user_per_minute": 60, "ip_per_minute": 120}

# ── Infrastructure (optional) ─────────────────────────────────────────────────
VECTOR_DB_URL=http://localhost:8000
REDIS_URL=                          # leave blank to use in-process rate limiting
ENVIRONMENT=development

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
AUDIT_LOG_FILE=logs/audit.log

# ── Internal API key ──────────────────────────────────────────────────────────
# Used by AuthManager for JWT signing. Set to any long random string.
API_KEY=replace-with-a-long-random-secret

# Do NOT commit your real .env file. This file is safe to commit.
